datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String     // Hashed password
  role          Role       @default(ADMIN)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  profile       Profile?
  blogPosts     BlogPost[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  title       String
  tagline     String
  bio         String   @db.Text
  avatarUrl   String?
  resumeUrl   String?
  githubUrl   String?
  linkedinUrl String?
  twitterUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String    @id @default(cuid())
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime? // Nullable for current job
  current     Boolean   @default(false)
  description String    @db.Text
  location    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // Frontend, Backend, DevOps, Design, etc.
  proficiency Int      // 1 to 100 percentage
  active      Boolean  @default(true)
  icon        String?  // Lucide icon name or SVG path
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  description  String         @db.Text
  content      String         @db.Text // Markdown details
  githubUrl    String?
  demoUrl      String?
  featured     Boolean        @default(false)
  active       Boolean        @default(true)
  techStack    String[]       // List of technologies (e.g., Next.js, Go)
  challenges   String         @db.Text
  solutions    String         @db.Text
  images       ProjectImage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  summary     String       @db.Text
  content     String       @db.Text // Markdown / Rich Text
  coverImage  String?
  published   Boolean      @default(false)
  archived    Boolean      @default(false)
  publishedAt DateTime?
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])
  tags        BlogTag[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
}

model BlogTag {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
